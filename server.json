{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.zhound420/d365fo-connector",
  "description": "Query and manage Microsoft Dynamics 365 Finance & Operations via MCP",
  "repository": {
    "url": "https://github.com/zhound420/D365FO-claude-connector",
    "source": "github"
  },
  "version": "2.0.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@zhound/d365fo-mcp-server",
      "version": "2.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "D365_TENANT_ID",
          "description": "Azure AD tenant ID",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        },
        {
          "name": "D365_CLIENT_ID",
          "description": "App registration client ID",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        },
        {
          "name": "D365_CLIENT_SECRET",
          "description": "App registration client secret",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "D365_ENVIRONMENT_URL",
          "description": "D365 F&O environment URL, e.g. https://contoso.operations.dynamics.com",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
